function RightTriangleDiagram({ vars }) {
  const { a, b } = vars;
  const c = Math.sqrt(a * a + b * b);
  const cLabel = Number.isInteger(c) ? `${c} cm` : "? cm";
  const W = 260, H = 180;
  const pad = 30;
  const scale = Math.min((W - pad * 2) / b, (H - pad * 2) / a);
  const bx = pad, by = pad + a * scale;
  const cx = pad + b * scale, cy = pad + a * scale;
  const ax = pad, ay = pad;
  const sqSize = 12;

  return (
    <svg width={W} height={H} className="w-full" viewBox={`0 0 ${W} ${H}`}>
      <defs>
        <marker id="arr" markerWidth="6" markerHeight="6" refX="3" refY="3" orient="auto">
          <path d="M0,0 L6,3 L0,6 Z" fill="#6366f1" />
        </marker>
      </defs>
      {/* Triangle */}
      <polygon points={`${ax},${ay} ${bx},${by} ${cx},${cy}`}
        fill="#6366f130" stroke="#6366f1" strokeWidth="2" strokeLinejoin="round" />
      {/* Right angle square */}
      <rect x={bx} y={by - sqSize} width={sqSize} height={sqSize}
        fill="none" stroke="#6366f180" strokeWidth="1.5" />
      {/* Labels */}
      <text x={ax - 20} y={(ay + by) / 2 + 5} fill="#a5b4fc" fontSize="13" fontFamily="Georgia" fontWeight="bold">{a} cm</text>
      <text x={(bx + cx) / 2 - 12} y={by + 20} fill="#a5b4fc" fontSize="13" fontFamily="Georgia" fontWeight="bold">{b} cm</text>
      <text x={(ax + cx) / 2 + 8} y={(ay + cy) / 2 - 6} fill="#67e8f9" fontSize="13" fontFamily="Georgia" fontWeight="bold"
        transform={`rotate(${-Math.atan2(ay - cy, cx - ax) * 180 / Math.PI}, ${(ax + cx) / 2}, ${(ay + cy) / 2})`}>
        {cLabel}
      </text>
      {/* Question mark dot */}
      <circle cx={(ax + cx) / 2} cy={(ay + cy) / 2} r="4" fill="#67e8f9" opacity="0.6" />
    </svg>
  );
}

function TriangleAnglesDiagram({ vars }) {
  const { a, b } = vars;
  const x = 180 - a - b;
  const W = 260, H = 180;
  const pts = [[130, 25], [30, 155], [230, 155]];
  const [A, B, C] = pts;

  const arcLabel = (corner, angle, label, color, offset = 28) => {
    const [px, py] = pts[corner];
    const neighbors = pts.filter((_, i) => i !== corner);
    const angles = neighbors.map(([nx, ny]) => Math.atan2(ny - py, nx - px));
    const mid = (angles[0] + angles[1]) / 2;
    return (
      <text key={label} x={px + Math.cos(mid) * offset} y={py + Math.sin(mid) * offset + 4}
        fill={color} fontSize="12" fontFamily="Georgia" fontWeight="bold" textAnchor="middle">
        {label}
      </text>
    );
  };

  return (
    <svg width={W} height={H} className="w-full" viewBox={`0 0 ${W} ${H}`}>
      <polygon points={pts.map(p => p.join(",")).join(" ")}
        fill="#6366f120" stroke="#6366f1" strokeWidth="2" strokeLinejoin="round" />
      {arcLabel(0, a, `${a}°`, "#a5b4fc", 26)}
      {arcLabel(1, b, `${b}°`, "#a5b4fc", 30)}
      {arcLabel(2, x, x > 0 ? "x°" : "?", "#67e8f9", 30)}
      {x > 0 && (
        <text x={pts[2][0] + 32} y={pts[2][1] + 4} fill="#67e8f980" fontSize="10" fontFamily="Georgia">(= {x}°)</text>
      )}
    </svg>
  );
}

