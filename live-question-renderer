        </div>

        {/* Diagram type badge */}
        <div className="flex items-center gap-2 -mt-2">
          <span className="text-xs text-slate-600">Renderer:</span>
          <span className="text-xs font-mono text-slate-500 bg-white/5 px-2 py-0.5 rounded">{family.diagramType}</span>
          <span className="text-xs text-slate-600 ml-auto">↑ redraws from data</span>
        </div>

        {/* Question text */}
        <div className="bg-white/5 border border-white/10 rounded-xl p-4">
          <p className="text-white text-sm leading-relaxed font-medium">{family.template(vars)}</p>
        </div>

        {/* Variable sliders (for geometric questions) */}
        {family.variableDefs.length > 0 && (
          <div className="flex flex-col gap-3 bg-white/3 border border-white/8 rounded-xl p-3">
            <p className="text-xs font-bold text-slate-400 uppercase tracking-widest">Adjust values → diagram updates live</p>
            {family.variableDefs.map(def => (
              <div key={def.key} className="flex items-center gap-3">
                <label className="text-xs text-slate-400 w-28 flex-shrink-0">{def.label}</label>
                <input type="range" min={def.min} max={def.max} step={def.step}
                  value={vars[def.key]}
                  onChange={e => updateVar(def.key, e.target.value)}
                  className="flex-1 accent-indigo-500 h-1.5" />
                <span className="text-white font-mono text-sm w-8 text-right">{vars[def.key]}</span>
              </div>
            ))}
          </div>
        )}

        {/* Table edit toggle */}
        {family.diagramType === "frequency_table" && (
          <button onClick={() => setEditTable(!editTable)}
            className="text-xs text-indigo-400 underline text-left">
            {editTable ? "Lock table values" : "✎ Edit table values live"}
          </button>
        )}

        {/* Variant switcher */}
        <div>
          <p className="text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Question variants (same structure, different values)</p>
          <div className="flex gap-2 flex-wrap">
            {family.variants.map((v, i) => (
              <button key={i} onClick={() => useVariant(i)}
                className="text-xs px-3 py-1.5 rounded-lg border font-semibold transition-all"
                style={{
                  background: variantIdx === i ? color + "30" : "transparent",
                  borderColor: variantIdx === i ? color : "#ffffff20",
                  color: variantIdx === i ? color : "#64748b",
                }}>
                Variant {i + 1}
              </button>
            ))}
          </div>
        </div>

        {/* Answer */}
        <div className="flex items-center justify-between bg-white/5 border border-white/10 rounded-xl px-4 py-3">
          <span className="text-xs text-slate-500 font-bold uppercase tracking-widest">Answer</span>
          <span className="font-mono text-sm font-bold" style={{ color }}>{family.answer(vars)}</span>
        </div>

        {/* Mark scheme toggle */}
        <button onClick={() => setShowScheme(!showScheme)}
          className="text-xs font-bold uppercase tracking-widest text-left transition-colors"
          style={{ color: showScheme ? color : "#475569" }}>
          {showScheme ? "▼ Hide mark scheme" : "▶ Show mark scheme"}
        </button>
        {showScheme && <MarkScheme items={family.markScheme(vars)} />}
      </div>
    </div>
  );
}

